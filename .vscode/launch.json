{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug", // Название режима (будет в выпадающем списке)
            "type": "cppdbg",     // Тип отладчика для C/C++
            "request": "launch",  // Запустить новую программу
            // ВАЖНО: Путь к вашему исполняемому файлу, который создается в папке build
            "program": "${workspaceFolder}/build/main.exe", 
            "args": [],           // Аргументы командной строки для программы
            "stopAtEntry": false, // Остановиться ли сразу на входе в main()
            "cwd": "${workspaceFolder}", // Рабочая директория при запуске
            "externalConsole": false,    // Использовать встроенный терминал VS Code
            "MIMode": "gdb",             // Тип отладчика (gdb, lldb, etc.)
            "miDebuggerPath": "/usr/bin/gdb", // Путь к gdb (на Windows: C:\\mingw64\\bin\\gdb.exe)
            "preLaunchTask": "Build All", // КЛЮЧЕВОЙ МОМЕНТ: запустить задачу сборки перед стартом!
            "setupCommands": [
                {
                    "description": "Включить красивое отображение STL контейнеров",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}